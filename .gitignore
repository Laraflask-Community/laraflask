# Environment
.env
.env.*.local

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.mypy_cache/

# Virtual environments
venv/
.venv/
env/

# Database
*.db
*.sqlite
*.sqlite3

# Storage — runtime content is ignored, but keep the folder structure
storage/app/*
!storage/app/public
storage/app/public/*
!storage/app/public/.gitkeep

storage/framework/cache/*
!storage/framework/cache/.gitkeep
storage/framework/sessions/*
!storage/framework/sessions/.gitkeep
storage/framework/views/*
!storage/framework/views/.gitkeep

storage/logs/*
!storage/logs/.gitkeep

# Public — user-uploaded/build content is ignored, but keep the folder
public/*
!public/.gitkeep

# Editor / OS
.vscode/
.idea/
.DS_Store
Thumbs.db

# Test artifacts
.coverage
htmlcov/
