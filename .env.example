##########################################################################
#  Laraflask Environment Configuration
#  Copy this file to .env and adjust values for your environment.
##########################################################################

APP_NAME=Laraflask
APP_ENV=local
APP_KEY=base64:changeme_run_python_artisan_key_generate
APP_DEBUG=true
APP_HOST=127.0.0.1
APP_PORT=8000
APP_URL=http://localhost:8000
APP_TIMEZONE=UTC
APP_LOCALE=en

# ─── Database ─────────────────────────────────────────────────────────────────
DB_CONNECTION=sqlite
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=database/laraflask.db
DB_USERNAME=root
DB_PASSWORD=
DB_POOL_SIZE=5
DB_POOL_OVERFLOW=10
DB_ECHO=false

# ─── Cache ────────────────────────────────────────────────────────────────────
CACHE_DRIVER=file
CACHE_PREFIX=laraflask_

# ─── Session ──────────────────────────────────────────────────────────────────
SESSION_DRIVER=filesystem
SESSION_LIFETIME=120

# ─── Queue ────────────────────────────────────────────────────────────────────
QUEUE_CONNECTION=sync

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_PREFIX=laraflask:

# ─── Mail ─────────────────────────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=hello@laraflask.dev
MAIL_FROM_NAME="${APP_NAME}"

# ─── File Storage ─────────────────────────────────────────────────────────────
FILESYSTEM_DISK=local

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_URL=
AWS_ENDPOINT_URL=

# ─── Authentication ───────────────────────────────────────────────────────────
JWT_SECRET=your-256-bit-secret
JWT_TTL=60

# ─── Telegram ─────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=

# ─── Twilio (SMS / WhatsApp) ──────────────────────────────────────────────────
TWILIO_SID=
TWILIO_TOKEN=
TWILIO_FROM=
TWILIO_WHATSAPP_FROM=

# ─── Firebase (Push) ──────────────────────────────────────────────────────────
FCM_SERVER_KEY=

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_CHANNEL=file
LOG_LEVEL=debug
